class Solution:
    def moveZeroes(self, nums):
        insert_pos = 0
        
        # First pass: move non-zero elements forward
        for num in nums:
            if num != 0:
                nums[insert_pos] = num
                insert_pos += 1
        
        # Second pass: fill the rest with zeros
        while insert_pos < len(nums):
            nums[insert_pos] = 0
            insert_pos += 1
