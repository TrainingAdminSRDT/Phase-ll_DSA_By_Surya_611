class Solution {
    public void moveZeroes(int[] nums) {
        int k = 0,a;
        for (int i = 0; i < nums.length; i++) {
            if (nums[i]!=0) {
                a=nums[i];
               nums[i]=nums[k];
               nums[k]=a;
               k++;
             }
        }
    }
}
