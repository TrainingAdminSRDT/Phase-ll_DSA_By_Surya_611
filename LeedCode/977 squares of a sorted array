class Solution {
    public int[] sortedSquares(int[] nums) {
        int l=nums.length;
        int arr[]=new int[l];
        int left=0;
        int right=l-1;
        int index=l-1;
        while(left<=right){
            int leftSquare=nums[left]*nums[left];
            int rightSquare=nums[right]*nums[right];
            if(leftSquare>rightSquare){
                arr[index]=leftSquare;
                left++;
            }
            else{
                arr[index]=rightSquare;
                right--;
            }index--;
        }
        return arr;
    }
}