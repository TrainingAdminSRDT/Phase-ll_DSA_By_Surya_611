class Solution {
    public int reverse(int x) {
        int a=x,c;
        long rev=0;
        
        while(a!=0)
        {
            c=a%10;
            rev=rev*10+c;
            a=a/10;
        }
        if (rev > Integer.MAX_VALUE || rev < Integer.MIN_VALUE) {
            return 0;
        }
        else{
            return(int) rev;
        }
      }
}
    